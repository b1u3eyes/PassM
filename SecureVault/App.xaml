<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="SecureVault.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <Color x:Key="VaultBgColor">#FF1A2332</Color>
            <Color x:Key="VaultPanelColor">#FF243447</Color>
            <Color x:Key="VaultAccentColor">#FF2B7FFF</Color>
            <Color x:Key="VaultTextColor">#FFF5F7FA</Color>
            <SolidColorBrush x:Key="VaultBgBrush" Color="{StaticResource VaultBgColor}" />
            <SolidColorBrush x:Key="VaultPanelBrush" Color="{StaticResource VaultPanelColor}" />
            <SolidColorBrush x:Key="VaultAccentBrush" Color="{StaticResource VaultAccentColor}" />
            <SolidColorBrush x:Key="VaultTextBrush" Color="{StaticResource VaultTextColor}" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
