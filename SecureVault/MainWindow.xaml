<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="SecureVault.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SecureVault"
    mc:Ignorable="d">
    <Grid Background="{StaticResource VaultBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="16,12"
            Background="{StaticResource VaultPanelBrush}">
            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{StaticResource VaultTextBrush}"
                Text="SecureVault" />
        </Border>

        <Frame
            x:Name="RootFrame"
            x:FieldModifier="public"
            Grid.Row="1"
            Background="Transparent" />
    </Grid>
</Window>
