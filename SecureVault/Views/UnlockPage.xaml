<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SecureVault.Views.UnlockPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    mc:Ignorable="d">
    <Grid Padding="32" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,16"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="{StaticResource VaultTextBrush}"
            Text="SecureVault" />

        <TextBlock
            x:Name="SubtitleText"
            Grid.Row="1"
            Margin="0,0,0,16"
            Foreground="{StaticResource VaultTextBrush}"
            Opacity="0.8"
            TextWrapping="WrapWholeWords" />

        <PasswordBox
            x:Name="MasterPasswordBox"
            Grid.Row="2"
            Margin="0,0,0,12"
            Header="Parolă master"
            PlaceholderText="Parolă"
            PasswordChanged="OnMasterPasswordChanged" />

        <StackPanel x:Name="ConfirmPanel" Grid.Row="3" Margin="0,0,0,12" Visibility="Collapsed">
            <PasswordBox
                x:Name="ConfirmPasswordBox"
                Margin="0,0,0,8"
                Header="Confirmare parolă"
                PasswordChanged="OnConfirmPasswordChanged"
                PlaceholderText="Repetați parola" />
            <TextBlock
                FontSize="12"
                Foreground="{StaticResource VaultTextBrush}"
                Opacity="0.7"
                Text="Filtrul Slabă e euristic local (fără internet)." />
        </StackPanel>

        <TextBlock
            Grid.Row="4"
            Margin="0,0,0,12"
            Foreground="#FFFFB74D"
            Text="{Binding ErrorMessage}"
            TextWrapping="WrapWholeWords"
            Visibility="{Binding ErrorVisibility}" />

        <StackPanel Grid.Row="5" Orientation="Horizontal">
            <Button
                x:Name="PrimaryActionButton"
                Margin="0,0,12,0"
                Background="{StaticResource VaultAccentBrush}"
                Command="{Binding UnlockCommand}"
                Content="Deblochează"
                Foreground="White" />
            <Button
                x:Name="CreateActionButton"
                Background="{StaticResource VaultAccentBrush}"
                Command="{Binding CreateCommand}"
                Content="Creează vault"
                Foreground="White"
                Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</Page>
