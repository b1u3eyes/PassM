<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SecureVault.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008">
    <Grid Background="{StaticResource VaultBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.Column="0"
            Padding="16"
            Background="{StaticResource VaultPanelBrush}"
            BorderBrush="#33FFFFFF"
            BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,12"
                FontSize="22"
                FontWeight="SemiBold"
                Foreground="{StaticResource VaultTextBrush}"
                Text="SecureVault" />

            <TextBox
                Grid.Row="1"
                Margin="0,0,0,8"
                Header="Căutare"
                PlaceholderText="Site, email, utilizator…"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Background="{StaticResource VaultAccentBrush}"
                    Command="{Binding SetFilterAllCommand}"
                    Content="Toate"
                    Foreground="White" />
                <Button
                    Margin="0,0,8,0"
                    Background="{StaticResource VaultAccentBrush}"
                    Command="{Binding SetFilterFavoritesCommand}"
                    Content="Favorite"
                    Foreground="White" />
                <Button
                    Background="{StaticResource VaultAccentBrush}"
                    Command="{Binding SetFilterWeakCommand}"
                    Content="Slabă"
                    Foreground="White"
                    ToolTipService.ToolTip="Euristică locală: lungime sub 12 sau set incomplet de caractere." />
            </StackPanel>

            <ListView
                Grid.Row="3"
                Margin="0,12,0,12"
                ItemsSource="{Binding FilteredEntries}"
                SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="4">
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{StaticResource VaultTextBrush}"
                                Text="{Binding DisplayTitle}" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{StaticResource VaultTextBrush}"
                                Opacity="0.75"
                                Text="{Binding Email}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="4" HorizontalAlignment="Center">
                <FontIcon
                    Margin="0,0,0,8"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="40"
                    Foreground="{StaticResource VaultAccentBrush}"
                    Glyph="&#xEA18;"
                    Opacity="0.85" />
                <Button
                    HorizontalAlignment="Stretch"
                    Command="{Binding NewEntryCommand}"
                    Content="Intrare nouă" />
            </StackPanel>
        </Grid>

        <ScrollViewer
            Grid.Column="1"
            Padding="24"
            VerticalScrollBarVisibility="Auto">
        <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource VaultTextBrush}"
                        Text="Detalii cont" />
                    <Border
                        Grid.Column="1"
                        MaxWidth="560"
                        Height="92"
                        Margin="16,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#0E0E16"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Image
                            x:Name="BannerImage"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Stretch="Uniform" />
                    </Border>
                    <Button
                        Grid.Column="2"
                        Command="{Binding LockCommand}"
                        Content="Blochează" />
                </Grid>

                <TextBox
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Header="Site"
                    Text="{Binding Site, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    Header="Email"
                    Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Grid.Row="3"
                    Margin="0,12,0,0"
                    Header="Utilizator"
                    Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <PasswordBox
                    x:Name="EditorPasswordBox"
                    Grid.Row="4"
                    Margin="0,12,0,0"
                    Header="Parolă"
                    PasswordRevealMode="Peek"
                    PasswordChanged="OnEditorPasswordChanged" />

                <TextBox
                    Grid.Row="5"
                    Margin="0,12,0,0"
                    Header="URL"
                    Text="{Binding Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Grid.Row="6"
                    Margin="0,12,0,0"
                    Header="Categorie"
                    Text="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="7" Margin="0,16,0,0" Orientation="Horizontal">
                    <Button
                        Margin="0,0,8,0"
                        Background="{StaticResource VaultAccentBrush}"
                        Command="{Binding CopyPasswordCommand}"
                        Content="Copiază parola"
                        Foreground="White" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{StaticResource VaultAccentBrush}"
                        Command="{Binding CopyUrlCommand}"
                        Content="Copiază URL"
                        Foreground="White" />
                    <Button
                        x:Name="FavoriteButton"
                        Margin="0,0,8,0"
                        Background="{StaticResource VaultAccentBrush}"
                        Command="{Binding ToggleFavoriteCommand}"
                        Content="☆"
                        FontSize="16"
                        Foreground="White"
                        ToolTipService.ToolTip="Favorite" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{StaticResource VaultAccentBrush}"
                        Command="{Binding GenerateCommand}"
                        Content="Generează"
                        Foreground="White" />
                    <Button
                        Margin="0,0,8,0"
                        Background="{StaticResource VaultAccentBrush}"
                        Command="{Binding SaveCommand}"
                        Content="Salvează"
                        Foreground="White" />
                    <Button Command="{Binding DeleteCommand}" Content="Șterge" />
                </StackPanel>

                <TextBlock
                    Grid.Row="8"
                    Margin="0,12,0,0"
                    Foreground="#FFFFB74D"
                    Text="{Binding StrengthLabel}" />
                <ProgressBar
                    Grid.Row="9"
                    Margin="0,8,0,0"
                    Maximum="1"
                    Minimum="0"
                    Value="{Binding StrengthRatio, Mode=OneWay}" />

                <StackPanel Grid.Row="10" Margin="0,12,0,0" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,6,0"
                        Foreground="{StaticResource VaultTextBrush}"
                        Text="Lungime:" />
                    <TextBlock Foreground="{StaticResource VaultTextBrush}" Text="{Binding GeneratorLength}" />
                </StackPanel>

                <Slider
                    Grid.Row="11"
                    Margin="0,8,0,0"
                    Maximum="64"
                    Minimum="8"
                    StepFrequency="1"
                    Value="{Binding GeneratorLength, Mode=TwoWay}" />

                <StackPanel Grid.Row="12" Margin="0,12,0,0" Orientation="Vertical">
                    <CheckBox Margin="0,0,0,4" Content="Litere mici (a-z)" IsChecked="{Binding GenUseLower, Mode=TwoWay}" />
                    <CheckBox Margin="0,0,0,4" Content="Litere mari (A-Z)" IsChecked="{Binding GenUseUpper, Mode=TwoWay}" />
                    <CheckBox Margin="0,0,0,4" Content="Cifre (0-9)" IsChecked="{Binding GenUseDigits, Mode=TwoWay}" />
                    <CheckBox Content="Simboluri (!@#$...)" IsChecked="{Binding GenUseSymbols, Mode=TwoWay}" />
                </StackPanel>

                <Grid Grid.Row="13" Margin="0,24,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Image
                            Width="36"
                            Height="36"
                            Margin="0,0,8,0"
                            Source="ms-appx:///Assets/StoreLogo.png" />
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,4,0"
                                Foreground="{StaticResource VaultTextBrush}"
                                Opacity="0.75"
                                Text="SecureVault" />
                            <TextBlock
                                Foreground="{StaticResource VaultTextBrush}"
                                Opacity="0.75"
                                Text="{Binding AppVersion}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

        </Grid>
        </ScrollViewer>
    </Grid>
</Page>
